        <!-- ── RELATIONSHIP EDGES ── -->
        <!-- FM → Events -->
        <mxCell id="r1" value="facilitates" edge="1" source="fm_card" target="ev" parent="1" style="curved=1;html=1;strokeColor=#06B6D4;fontColor=#06B6D4;fontSize=10;fontStyle=1;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
