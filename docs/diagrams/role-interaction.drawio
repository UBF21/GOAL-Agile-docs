<mxfile host="Claude" version="1.0">
  <diagram id="role-interaction" name="GOAL Role Interaction">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="8" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="640" math="0" shadow="0" background="#0B1220">
