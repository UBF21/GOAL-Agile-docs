        <mxCell id="r2" value="defines goals" edge="1" source="ps_card" target="ev" parent="1" style="curved=1;html=1;strokeColor=#14B8A6;fontColor=#14B8A6;fontSize=10;fontStyle=1;strokeWidth=2;endArrow=block;endFill=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Events → DT (delivers) -->
        <mxCell id="r3" value="commits &amp; delivers" edge="1" source="dt_card" target="ev" parent="1" style="curved=1;html=1;strokeColor=#34D399;fontColor=#34D399;fontSize=10;fontStyle=1;strokeWidth=2;endArrow=block;endFill=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
