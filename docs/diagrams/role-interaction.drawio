        <mxCell id="dt_title" value="Delivery Team" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontStyle=1;fontColor=#34D399;" vertex="1" parent="1">
          <mxGeometry x="430" y="454" width="240" height="28" as="geometry" />
        </mxCell>
        <mxCell id="dt_desc" value="Self-organizes execution&#xa;Pulls tasks (never pushed)&#xa;Raises blockers immediately" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#94A3B8;verticalAlign=top;" vertex="1" parent="1">
