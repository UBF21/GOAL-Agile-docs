          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- PS → DT (clarifies) -->
        <mxCell id="r6" value="clarifies scope" edge="1" source="ps_card" target="dt_card" parent="1" style="curved=1;html=1;strokeColor=#14B8A6;fontColor=#94A3B8;fontSize=9;strokeWidth=1.5;dashed=1;dashPattern=6 3;endArrow=open;endFill=0;exitX=0.25;exitY=1;entryX=1;entryY=0.3;">
