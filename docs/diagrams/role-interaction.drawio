        </mxCell>

        <!-- Events center node -->
        <mxCell id="ev" value="All 3 roles collaborate&#xa;in GOAL Events" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#14B8A6;fontColor=#F8FAFC;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
