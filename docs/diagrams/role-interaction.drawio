        </mxCell>
        <mxCell id="ps_desc" value="Owns value &amp; backlog&#xa;Defines goals (P-S-T format)&#xa;Prioritizes by value score&#xa;Stakeholder liaison&#xa;Manages GoalLog" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#94A3B8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="812" y="316" width="224" height="112" as="geometry" />
        </mxCell>

        <!-- Delivery Team (BOTTOM CENTER) -->
        <mxCell id="dt_card" value="" style="rounded=1;arcSize=8;fillColor=#0B1220;strokeColor=#34D399;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="430" y="400" width="240" height="200" as="geometry" />
