          <mxGeometry x="56" y="262" width="240" height="28" as="geometry" />
        </mxCell>
        <mxCell id="fm_role" value="Scrum Master equivalent" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontColor=#475569;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="56" y="288" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="fm_desc" value="Guards process &amp; flow&#xa;Enforces WIP limits&#xa;Removes blockers&#xa;Facilitates all events&#xa;Tracks flow metrics" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#94A3B8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="64" y="316" width="224" height="112" as="geometry" />
        </mxCell>

        <!-- Product Strategist (RIGHT) -->
        <mxCell id="ps_card" value="" style="rounded=1;arcSize=8;fillColor=#0B1220;strokeColor=#14B8A6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="804" y="200" width="240" height="280" as="geometry" />
