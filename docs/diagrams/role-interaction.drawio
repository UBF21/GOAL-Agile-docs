        </mxCell>
        <mxCell id="ps_title" value="Product Strategist" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontStyle=1;fontColor=#14B8A6;" vertex="1" parent="1">
          <mxGeometry x="804" y="262" width="240" height="28" as="geometry" />
